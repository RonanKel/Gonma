  lines:
  - speakerName: Hookfish
    dialogueText: I found this hook on the end of your line, mind if I keep it?
  - speakerName: Hookfish
    dialogueText: "It just looks so shiny\u2026"
  - speakerName: Hookfish
    dialogueText: " and sharp\u2026"
  - speakerName: Hookfish
    dialogueText: "and metallic\u2026"
  - speakerName: Hookfish
    dialogueText: "and precious?\u2026"
